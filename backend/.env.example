APP_NAME="WP Studio API"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# Comma-separated list of origins allowed to make credentialed
# cross-origin requests (see config/cors.php). The Next.js dev server.
FRONTEND_URLS=http://localhost:3000

# Domains allowed to receive stateful (cookie-based) Sanctum auth — see
# docs/adr/0006-authentication-architecture.md. Sanctum SPA auth requires
# the frontend and backend to share a registrable domain in production
# (e.g. app.example.com + api.example.com); a real value here is a
# deferred Milestone 19 (Cloud Deployment) decision, not yet made.
SANCTUM_STATEFUL_DOMAINS=localhost:3000,127.0.0.1:3000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug
# One JSON object per log line (request_id, level, message, context) instead
# of a human-oriented string — off by default so local `tail -f` stays
# readable; a production deploy would set this to true for log-aggregation
# tooling (CloudWatch/Datadog/ELK). See docs/adr/0016-observability.md.
LOG_JSON=false

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

# Disk the Media Platform (Milestone 12) stores uploads and WordPress-synced
# assets on — deliberately independent of FILESYSTEM_DISK; see config/media.php.
MEDIA_DISK=public
MEDIA_MAX_UPLOAD_KB=10240

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Error monitoring (Milestone 18) — see config/sentry.php and
# docs/adr/0016-observability.md. Unset means the SDK is a safe no-op;
# set to a real Sentry project DSN to actually report errors.
SENTRY_LARAVEL_DSN=

# Not implemented — distributed tracing is disproportionate infrastructure
# for this project's scope (no collector/backend to receive traces exists
# in any environment this app runs in). See docs/adr/0016-observability.md.
# OTEL_EXPORTER_OTLP_ENDPOINT=

# AI-Assisted Content Generation (Milestone 14) — see config/ai.php and
# docs/adr/0012-ai-content-generation.md. Required for the Dashboard's
# AI Assistant "Generate" action; a missing key surfaces as a clean 500
# (AI_CONFIGURATION_ERROR), never a raw SDK exception.
# AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-opus-4-8
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash
# AI_MAX_TOKENS=2048
